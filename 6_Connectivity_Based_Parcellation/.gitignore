# =============================================================================
# .gitignore for 6_Connectivity_Based_Parcellation
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Virtual environments ----
.venv/
venv/
env/

# ---- IDE / OS ----
.vscode/
.idea/
*.swp
.DS_Store

# ---- CBPtools driver code & workspace (not part of public release) ----
# The CBPtools pipeline (per-dataset YAML + shell scripts) and its raw workspace
# (group / individual / log) are run externally; only the final group parcellation
# maps under `data/cbptools/<dataset>/K{2..6}.nii.gz` and `internal_validity.tsv`
# are shipped.
codes/cbptools/
codes/useless/
results/cbptools/
results/nii_old/
results/temp/
results/nii_by_label/
results/gii/
results/gii_by_label/

# ---- Heavy upstream datasets (regenerable / externally distributed) ----
# Neurosynth term-association meta-analysis data; download from neurosynth.org
# (or via `neurosynth.Dataset.load(...)`) before running `4_Decode_Parcel.ipynb`.
data/neurosynth_data/

# ---- Subject lists (kept outside the public repository) ----
data/*_resting.tsv
data/*_subject.tsv
data/*_participants.tsv

# ---- dHCP cohort (excluded from this study) ----
# The dHCP preterm-neonatal cohort is not included in Study 4.
*dHCP*
*dhcp*

# ---- GIfTI per-label split products (regenerable via wb_command) ----
*.gii
*.gii.gz

# ---- Build / dist / logs ----
build/
dist/
*.egg-info/
*.log
*.tmp
